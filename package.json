{
  "name": "projects-personal-manager",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "registry": "bun scripts/generate-registry.ts",
    "programs": "bun scripts/sync-programs.ts",
    "ai-projects": "bun scripts/sync-ai-projects.ts",
    "agent:id": "bun scripts/get-agent-id.ts",
    "agent:start": "bun scripts/agent-start.ts",
    "agent:finish": "bun scripts/agent-finish.ts",
    "task:create": "bun scripts/create-task.ts",
    "lock:create": "bun scripts/create-lock.ts",
    "lock:list": "bun scripts/list-locks.ts",
    "lock:release": "bun scripts/release-lock.ts",
    "lock:refresh": "bun scripts/refresh-lock.ts",
    "check": "bun run check:consistency && bun run check:concurrency",
    "check:consistency": "bun scripts/check-consistency.ts",
    "check:concurrency": "bun scripts/check-concurrency.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
