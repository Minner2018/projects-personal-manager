# 本地生成的项目集索引
/registry.yaml

# vscode 配置文件
.vscode/

# 依赖目录
/node_modules/

# 项目默认只保留在本地
/projects/*

# 项目组默认只保留在本地
/programs/*

# 阅读资源默认只保留在本地
/reading-resources/*
!/reading-resources/projects/
!/reading-resources/未分类/
/reading-resources/projects/*
/reading-resources/未分类/*

# AI 项目摘要默认只保留在本地
/ai/projects/*

# AI 任务记录默认只保留在本地
/ai/tasks/*

# AI 并发锁默认只保留在本地
/ai/locks/*

# AI 记忆默认只保留在本地
/ai/memory/*
!/ai/memory/projects/

# 脚本备份文件
*.bak

# 迁移过程中文件
/old-ai/
/old-scripts/
/system-docs/OMP迁移说明.md
